{
  "name": "ThreatGuardAI",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "postCreateCommand": "npm install",
  "forwardPorts": [5173, 3000],
  "portsAttributes": {
    "5173": {
      "label": "Vite",
      "onAutoForward": "openBrowser"
    },
    "3000": {
      "label": "Express Dev Server",
      "onAutoForward": "notify"
    }
  }
}
